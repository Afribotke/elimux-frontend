# ElimuX frontend - environment variables
# Copy to .env.local for local development. In production these are set in the
# Vercel dashboard (Settings -> Environment Variables).

# Backend API base URL
NEXT_PUBLIC_API_URL=

# Supabase (publishable/anon key only - never the service-role key here)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Feature flags ('true' enables, anything else disables)
# University & College / Skills & Trades toggle on the AI search page
NEXT_PUBLIC_FEATURE_SKILLS_TOGGLE=true
